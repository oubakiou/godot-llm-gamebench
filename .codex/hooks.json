{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch|ApplyPatch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/run-check-file.ts\"",
            "statusMessage": "check file"
          }
        ]
      }
    ]
  }
}

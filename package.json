{
  "name": "typescript-agent-package-template",
  "version": "0.1.0",
  "description": "Template for TypeScript npm packages with Codex/Claude project automation.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "bench:grade": "node src/bench/cli.ts grade",
    "bench:report": "node src/bench/cli.ts report",
    "bench:run": "node src/bench/cli.ts run",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "pack:check": "npm run check && npm run test && npm run build && npm pack --dry-run",
    "test": "vp test"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "2.1.200",
    "@openai/codex": "0.142.3",
    "@types/node": "^24.0.0",
    "md2idx": "^0.2.0",
    "mdxg-redline": "^0.1.3",
    "oxlint-tsgolint": "0.x",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.1.3",
    "vite-plus": "^0.x",
    "vitest": "^4.1.1"
  }
}
